{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {}
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "shrimp-task-manager": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@cjo4m06/mcp-shrimp-task-manager"],
      "env": {
        "DATA_DIR": "./shrimp_data"
      }
    }
  }
}
